# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET     /                           controllers.HomeController.index()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)

GET     /health                                    controllers.SecurityController.health()
POST    /api/v1/inspeccionar                       controllers.SecurityController.inspeccionar()
GET     /api/v1/inspecciones                       controllers.SecurityController.listarInspecciones()
GET     /api/v1/inspecciones/vuelo/:vueloId        controllers.SecurityController.listarPorVuelo(vueloId: String)
GET     /api/v1/inspecciones/equipaje/:equipajeId  controllers.SecurityController.buscarPorEquipaje(equipajeId: String)